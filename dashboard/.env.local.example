# Copy to .env.local (gitignored) and fill in the real key.
#
# Server-side only: read by the Next.js route handlers in app/api/*, which
# proxy browser requests to the Go API and attach the key there. Must match
# the SECUREPAY_API_KEY the Go server was started with.
#
# Do NOT rename this with a NEXT_PUBLIC_ prefix and do NOT reference it in
# any "use client" file — either would ship the key to the browser.
SECUREPAY_API_KEY=replace-with-the-same-key-as-the-go-api

# Optional: where the Go API listens (defaults to http://localhost:8080).
# SECUREPAY_API_BASE=http://localhost:8080
