# SecurePay Verify API configuration.
# Copy to .env (or export directly) before starting the Go server.

# Shared API key required on every request as the X-API-Key header.
# The server refuses to start if this is unset.
# Generate a value with: openssl rand -hex 32
SECUREPAY_API_KEY=replace-with-a-long-random-string

# Turso (libSQL) database. Both server and seed refuse to start if unset.
# Setup (see https://docs.turso.tech):
#   1. Install the CLI:        brew install tursodatabase/tap/turso
#   2. Sign up / log in:       turso auth signup   (or: turso auth login)
#   3. Create the database:    turso db create securepay-verify
#   4. Get the URL:            turso db show securepay-verify --url
#   5. Create an auth token:   turso db tokens create securepay-verify
TURSO_DATABASE_URL=libsql://securepay-verify-<your-org>.turso.io
TURSO_AUTH_TOKEN=replace-with-output-of-turso-db-tokens-create
